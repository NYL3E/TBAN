# Copier ce fichier en .env et adapter les valeurs.
# (Sur Coolify, ces variables se renseignent dans l'onglet "Environment Variables".)

# Port HTTP exposé par l'application
PORT=3000

# Identifiants PostgreSQL (utilisés par le service "db" du docker-compose)
POSTGRES_USER=flappy
POSTGRES_PASSWORD=change-moi-en-production
POSTGRES_DB=flappy

# Chaîne de connexion utilisée par l'application.
# En docker-compose, l'hôte est "db" (le nom du service de base de données).
DATABASE_URL=postgres://flappy:change-moi-en-production@db:5432/flappy
